# ============================================================================
# CODM Bot - Configuration Template
# ============================================================================
# Copy this file to .env and fill in your values:
#   cp .env.example .env
#
# NOTE: This file is automatically created by deploy.sh during installation.
# ============================================================================

# ----------------------------------------------------------------------------
# Telegram Bot Configuration (REQUIRED)
# ----------------------------------------------------------------------------

# Bot token from @BotFather
BOT_TOKEN=your_bot_token_here

# Your Telegram user ID (get it from @userinfobot)
SUPER_ADMIN_ID=123456789

# ----------------------------------------------------------------------------
# Database Configuration (REQUIRED)
# ----------------------------------------------------------------------------

# PostgreSQL connection string
DATABASE_URL=postgresql://user:pass@localhost:5432/dbname

# Database backend (only postgres supported)
DATABASE_BACKEND=postgres

# ----------------------------------------------------------------------------
# Connection Pool Settings
# ----------------------------------------------------------------------------

DB_POOL_SIZE=20
DB_POOL_MAX_OVERFLOW=10
DB_POOL_TIMEOUT=30
DB_POOL_RECYCLE=3600

# ----------------------------------------------------------------------------
# Language Settings
# ----------------------------------------------------------------------------

DEFAULT_LANG=fa
SUPPORTED_LANGS=fa,en
FALLBACK_LANG=en

# ----------------------------------------------------------------------------
# Performance & Caching
# ----------------------------------------------------------------------------

CACHE_ENABLED=true
CACHE_TTL_CATEGORIES=3600
CACHE_TTL_WEAPONS=1800
CACHE_TTL_ATTACHMENTS=300

# Slow query logging
LOG_SLOW_QUERIES=true
SLOW_QUERY_THRESHOLD=100

# ----------------------------------------------------------------------------
# Environment
# ----------------------------------------------------------------------------

ENVIRONMENT=production
DEBUG_MODE=false

# ----------------------------------------------------------------------------
# Logging
# ----------------------------------------------------------------------------

DB_LOG_LEVEL=INFO
LOG_DB_QUERIES=false

# ----------------------------------------------------------------------------
# Network & Proxy Settings (Optional)
# ----------------------------------------------------------------------------

# Explicit proxy URL (e.g., http://127.0.0.1:1080)
# Set to 'NONE' to force direct connection and ignore system proxies
# BOT_PROXY_URL=NONE

# Timeouts for Telegram requests (seconds)
BOT_REQUEST_TIMEOUT=60
BOT_CONNECT_TIMEOUT=30

# ----------------------------------------------------------------------------
# Webhook Configuration (Optional - Default is Polling)
# ----------------------------------------------------------------------------

# Bot running mode: "polling" (default) or "webhook"
BOT_MODE=polling

# Webhook settings (only needed if BOT_MODE=webhook)
# WEBHOOK_URL=https://your-domain.com
# WEBHOOK_PORT=8443
# WEBHOOK_PATH=/webhook
